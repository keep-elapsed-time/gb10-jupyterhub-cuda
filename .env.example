# Copy to .env and fill in values
JUPYTERHUB_ADMIN=aifintech
DOCKER_NETWORK_NAME=jupyterhub-net

# Set this to the IP/hostname users use to access JupyterHub in their browser.
# This MUST match the address in the browser URL bar — cookie origin must match.
JUPYTERHUB_PUBLIC_HOST=192.168.21.3
JUPYTERHUB_PUBLIC_PORT=8000
